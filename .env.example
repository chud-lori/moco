# Moco environment template — copy to .env and fill in.
# `.env` is gitignored. Never commit real secrets.

# ---------- Server ----------
# Address to bind. ":8080" listens on all interfaces.
MOCO_ADDR=:8080
# Where SQLite + (when local backend) book files live.
MOCO_DATA_DIR=var
# Set to true behind HTTPS so cookies are flagged Secure.
MOCO_SECURE_COOKIES=false
# Canonical public URL for OG / Twitter Card meta tags. Optional.
# MOCO_PUBLIC_URL=https://moco.example.com

# ---------- Docker host port (compose file only) ----------
# Host port mapped to the container. Always bound to 127.0.0.1 — public
# access goes through nginx. Override if 6666 is already taken on the host.
MOCO_PORT=6666

# ---------- Storage backend ----------
# Backend to use: "local" (default) or "r2". Local stores book files under
# MOCO_DATA_DIR. R2 uploads to a Cloudflare bucket.
#
# Default is "local" so dev environments can have the R2 credentials sitting
# in .env (for poking at the bucket via scripts) without accidentally writing
# real uploads there. Set MOCO_STORAGE=r2 in production.
MOCO_STORAGE=local

# Cloudflare R2 — only used when MOCO_STORAGE=r2.
MOCO_R2_ACCOUNT_ID=
MOCO_R2_ACCESS_KEY_ID=
MOCO_R2_SECRET_ACCESS_KEY=
MOCO_R2_BUCKET=

# Key prefix — lets one bucket host multiple environments.
# Use "prod" in production. Empty in single-env setups.
MOCO_STORAGE_PREFIX=
