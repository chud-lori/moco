# Moco environment template — copy to .env and fill in.
# `.env` is gitignored. Never commit real secrets.

# ---------- Server ----------
# Address to bind. ":8080" listens on all interfaces.
MOCO_ADDR=:8080
# Where SQLite + (when local backend) book files live.
MOCO_DATA_DIR=var
# Set to true behind HTTPS so cookies are flagged Secure.
MOCO_SECURE_COOKIES=false
# Canonical public URL for OG / Twitter Card meta tags. Optional.
# MOCO_PUBLIC_URL=https://moco.example.com

# ---------- Storage backend ----------
# Force the local filesystem even when R2 vars are set. Useful in dev.
# MOCO_STORAGE=local

# Cloudflare R2 (S3-compatible). When all four are set, R2 is used automatically.
MOCO_R2_ACCOUNT_ID=
MOCO_R2_ACCESS_KEY_ID=
MOCO_R2_SECRET_ACCESS_KEY=
MOCO_R2_BUCKET=

# Key prefix — lets one bucket host multiple environments.
# Use "dev" locally, "prod" in production. Empty for single-env setups.
MOCO_STORAGE_PREFIX=dev
