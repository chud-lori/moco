# Moco environment template — copy to .env and fill in.
# `.env` is gitignored. Never commit real secrets.

# ---------- Server ----------
# Address to bind. ":8080" listens on all interfaces.
MOCO_ADDR=:8080
# Where SQLite + (when local backend) book files live.
MOCO_DATA_DIR=var
# Set to true behind HTTPS so cookies are flagged Secure.
MOCO_SECURE_COOKIES=false
# Canonical public URL for OG / Twitter Card meta tags. Optional.
# MOCO_PUBLIC_URL=https://moco.example.com

# ---------- Docker host port (compose file only) ----------
# Host port mapped to the container. Always bound to 127.0.0.1 — public
# access goes through nginx. Override if 8666 is already taken on the host.
# Avoid Chromium's blocked-port list (e.g. 6666 = IRC, 6000 = X11).
MOCO_PORT=8666

# ---------- Storage backend ----------
# Backend to use: "local" (default) or "r2". Local stores book files under
# MOCO_DATA_DIR. R2 uploads to a Cloudflare bucket.
#
# Default is "local" so dev environments can have the R2 credentials sitting
# in .env (for poking at the bucket via scripts) without accidentally writing
# real uploads there. Set MOCO_STORAGE=r2 in production.
MOCO_STORAGE=local

# Cloudflare R2 — only used when MOCO_STORAGE=r2.
MOCO_R2_ACCOUNT_ID=
MOCO_R2_ACCESS_KEY_ID=
MOCO_R2_SECRET_ACCESS_KEY=
MOCO_R2_BUCKET=

# Key prefix — lets one bucket host multiple environments.
# Use "prod" in production. Empty in single-env setups.
MOCO_STORAGE_PREFIX=

# ---------- Google OAuth ("Continue with Google") ----------
# All three must be set to enable Google sign-in. Leave any blank to disable —
# the OAuth routes return 503 and the button is hidden on /login + /signup.
#
# Create credentials at Google Cloud Console → APIs & Services → Credentials
# → OAuth 2.0 Client ID (Web application). Add these URIs to the client's
# "Authorized redirect URIs":
#   https://your-domain/api/v1/auth/google/callback
#   http://localhost:8666/api/v1/auth/google/callback   (for local dev)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must EXACTLY match one of the redirect URIs registered above.
GOOGLE_OAUTH_REDIRECT_URL=https://your-domain/api/v1/auth/google/callback
